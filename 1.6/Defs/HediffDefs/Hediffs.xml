<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <HediffDef>
        <defName>Hediff_TemporalSurge</defName>
        <label>temporal surge</label>
        <description>The pawn is moving and working at hyperspeed. Time flows rapidly around them, accelerating all processes—including aging.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <isBad>false</isBad>
        <comps>
            <li Class="HediffCompProperties_Disappears">
                <disappearsAfterTicks>3600</disappearsAfterTicks>
                <showRemainingTime>true</showRemainingTime>
            </li>
            <li Class="RsPandaLibrary.HediffCompProperties_IgnorePathCost" />
        </comps>
        <stages>
            <li>
                <statFactors>
                    <AimingDelayFactor>0.67</AimingDelayFactor>
                    <MoveSpeed>1.5</MoveSpeed>
                    <WorkSpeedGlobal>1.5</WorkSpeedGlobal>
                </statFactors>
                <statOffsets>
                    <MeleeCooldownFactor>-0.37</MeleeCooldownFactor>
                    <RangedCooldownFactor>-0.37</RangedCooldownFactor>
                </statOffsets>
            </li>
        </stages>
    </HediffDef>

    <HediffDef>
        <defName>PM_Floating</defName>
        <label>Floating</label>
        <description>This unit is floating with its anti-gravity core.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <isBad>false</isBad>
        <defaultLabelColor>(0.6,0.8,0.6)</defaultLabelColor>
        <comps>
            <li Class="HediffCompProperties_DisappearsOnDeath" />
            <li Class="RsPandaLibrary.HediffCompProperties_IgnorePathCost" />
        </comps>
    </HediffDef>


    <HediffDef>
        <defName>PM_Hediff_GuardianShieldActive</defName>
        <label>guardian shield active</label>
        <description>This mechanoid is activated its shield component.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <defaultLabelColor>(0.6, 0.8, 0.9)</defaultLabelColor>
        <isBad>false</isBad>
        <comps>
            <li Class="ProtossMech.HediffCompProperties_ShieldControl" />
            <li Class="HediffCompProperties_Disappears">
                <disappearsAfterTicks>900</disappearsAfterTicks>
                <showRemainingTime>true</showRemainingTime>
            </li>
        </comps>
    </HediffDef>

    <HediffDef>
        <defName>Hediff_Reconstruct</defName>
        <label>Reconstruct NanoMachine Swarm</label>
        <description>This pawn just got reconstructed—its body's still made up of active nanomachines, so no matter how beat up it gets, it heals super fast.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <isBad>false</isBad>
        <comps>
            <li Class="HediffCompProperties_Disappears">
                <disappearsAfterTicks>300</disappearsAfterTicks>
                <showRemainingTime>true</showRemainingTime>
            </li>
        </comps>
        <stages>
            <li>
                <statFactors>
                    <IncomingDamageFactor>0</IncomingDamageFactor>
                    <MoveSpeed>-10.0</MoveSpeed>
                </statFactors>
            </li>
        </stages>
    </HediffDef>

    <HediffDef>
        <defName>Hediff_Charging</defName>
        <label>charging</label>
        <description>This unit is charging.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <isBad>false</isBad>
        <comps>
            <li Class="HediffCompProperties_Disappears">
                <disappearsAfterTicks>180</disappearsAfterTicks>
                <showRemainingTime>true</showRemainingTime>
            </li>
            <li Class="RsPandaLibrary.HediffCompProperties_IgnorePathCost" />
        </comps>
        <stages>
            <li>
                <statFactors>
                    <MoveSpeed>6.0</MoveSpeed>
                </statFactors>
            </li>
        </stages>
    </HediffDef>

    <HediffDef>
        <defName>PMP_DisruptorInvisibility</defName>
        <label>DisruptorInvisibility</label>
        <hediffClass>HediffWithComps</hediffClass>
        <description>A light-distorting field renders this unit invisible to the naked eye.</description>
        <isBad>false</isBad>
        <comps>
            <li Class="HediffCompProperties_Invisibility">
                <visibleToPlayer>true</visibleToPlayer>
            </li>
            <li Class="HediffCompProperties_DisappearsOnDeath" />
        </comps>
    </HediffDef>

    <HediffDef>
        <defName>PMP_HelperAssist</defName>
        <label>Helper assistant</label>
        <description>Servitor Drone is assisting with this mechanitor's work.</description>
        <hediffClass>ProtossMech.Hediff_PMP_HelperAssist</hediffClass>
        <defaultLabelColor>(0.6, 0.8, 1.0)</defaultLabelColor>
        <isBad>false</isBad>
        <stages>
            <li>
                <minSeverity>1</minSeverity>
                <label>x1</label>
                <statOffsets>
                    <WorkSpeedGlobal>0.10</WorkSpeedGlobal>
                </statOffsets>
            </li>
            <li>
                <minSeverity>2</minSeverity>
                <label>x2</label>
                <statOffsets>
                    <WorkSpeedGlobal>0.20</WorkSpeedGlobal>
                </statOffsets>
            </li>
            <li>
                <minSeverity>3</minSeverity>
                <label>x3</label>
                <statOffsets>
                    <WorkSpeedGlobal>0.30</WorkSpeedGlobal>
                </statOffsets>
            </li>
            <li>
                <minSeverity>4</minSeverity>
                <label>x4</label>
                <statOffsets>
                    <WorkSpeedGlobal>0.40</WorkSpeedGlobal>
                </statOffsets>
            </li>
            <li>
                <minSeverity>5</minSeverity>
                <label>x5</label>
                <statOffsets>
                    <WorkSpeedGlobal>0.50</WorkSpeedGlobal>
                </statOffsets>
            </li>
            <li>
                <minSeverity>6</minSeverity>
                <label>x6</label>
                <statOffsets>
                    <WorkSpeedGlobal>0.60</WorkSpeedGlobal>
                </statOffsets>
            </li>
            <li>
                <minSeverity>7</minSeverity>
                <label>x7</label>
                <statOffsets>
                    <WorkSpeedGlobal>0.70</WorkSpeedGlobal>
                </statOffsets>
            </li>
            <li>
                <minSeverity>8</minSeverity>
                <label>x8</label>
                <statOffsets>
                    <WorkSpeedGlobal>0.80</WorkSpeedGlobal>
                </statOffsets>
            </li>
            <li>
                <minSeverity>9</minSeverity>
                <label>x9</label>
                <statOffsets>
                    <WorkSpeedGlobal>0.90</WorkSpeedGlobal>
                </statOffsets>
            </li>
            <li>
                <minSeverity>10</minSeverity>
                <label>x10</label>
                <statOffsets>
                    <WorkSpeedGlobal>1.00</WorkSpeedGlobal>
                </statOffsets>
            </li>
        </stages>
    </HediffDef>

    <HediffDef>
        <defName>PMP_PrideOfTemplar</defName>
        <label>Pride of the Templar</label>
        <description>I Fight for my people, fears can not defeat me.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <defaultLabelColor>(0.8, 0.6, 0.2)</defaultLabelColor>
        <isBad>false</isBad>
        <comps>
            <li Class="HediffCompProperties_Disappears">
                <disappearsAfterTicks>60000</disappearsAfterTicks>
            </li>
        </comps>
        <stages>
            <li>
                <label>activate</label>
                <statFactors>
                    <IncomingDamageFactor>0.5</IncomingDamageFactor>
                </statFactors>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>0.5</offset>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>

    <!-- Artanis storyteller: short-term buff when a colonist dies (other colonists get Revenge). -->
    <HediffDef>
        <defName>PM_Artanis_Revenge</defName>
        <label>revenge</label>
        <description>A colonist has fallen. The survivors are driven by vengeance.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <defaultLabelColor>(0.9, 0.3, 0.2)</defaultLabelColor>
        <isBad>false</isBad>
        <comps>
            <li Class="HediffCompProperties_Disappears">
                <disappearsAfterTicks>4800</disappearsAfterTicks>
                <showRemainingTime>true</showRemainingTime>
            </li>
        </comps>
        <stages>
            <li>
                <statFactors>
                    <ShootingAccuracyPawn>1.15</ShootingAccuracyPawn>
                    <MeleeHitChance>1.10</MeleeHitChance>
                    <WorkSpeedGlobal>1.10</WorkSpeedGlobal>
                </statFactors>
                <statOffsets>
                    <MentalBreakThreshold>0.05</MentalBreakThreshold>
                </statOffsets>
            </li>
        </stages>
    </HediffDef>

    <!-- Artanis storyteller: permanent buff that scales with number of raids survived. Dynamically generated by severity (raid count); no cap. -->
    <HediffDef>
        <defName>PM_Artanis_Veteran</defName>
        <label>Battle-Hardened</label>
        <description>This colonist has been tempered by countless raids and grown stronger for it.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <defaultLabelColor>(0.4, 0.7, 0.9)</defaultLabelColor>
        <isBad>false</isBad>
        <!-- No maxSeverity: severity = raid count, unbounded. Stat offsets are computed by valueBySeverity curves. -->
        <stages>
            <li>
                <minSeverity>0</minSeverity>
                <label>Battle-Hardened</label>
                <statOffsetsBySeverity>
                    <!-- Offset = x per raid (linear). Curve extrapolates for severity beyond 100. -->
                    <li Class="StatModifierBySeverity">
                        <stat>ShootingAccuracyPawn</stat>
                        <valueBySeverity>
                            <points>
                                <li>(0, 0)</li>
                                <li>(1, 0.1)</li>
                                <li>(10, 1.0)</li>
                                <li>(100, 10.0)</li>
                            </points>
                        </valueBySeverity>
                    </li>
                    <li Class="StatModifierBySeverity">
                        <stat>MeleeHitChance</stat>
                        <valueBySeverity>
                            <points>
                                <li>(0, 0)</li>
                                <li>(1, 0.1)</li>
                                <li>(10, 1.0)</li>
                                <li>(100, 10.0)</li>
                            </points>
                        </valueBySeverity>
                    </li>
                    <li Class="StatModifierBySeverity">
                        <stat>GlobalLearningFactor</stat>
                        <valueBySeverity>
                            <points>
                                <li>(0, 0)</li>
                                <li>(1, 0.1)</li>
                                <li>(10, 1.0)</li>
                                <li>(100, 10.0)</li>
                            </points>
                        </valueBySeverity>
                    </li>
                </statOffsetsBySeverity>
            </li>
        </stages>
    </HediffDef>

</Defs>