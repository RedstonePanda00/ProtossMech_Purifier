    <!-- Resurrection -->

    <RecipeDef ParentName="BaseMechanoidResurrectionRecipe">
        <defName>ResurrectProtossMechLight</defName>
        <label>resurrect Light Protoss mechanoid</label>
        <description>Resurrect a friendly mechanoid of the Protoss class. So long as the mechanoid's body is not completely destroyed, it can be resurrected.</description>
        <ingredients>
            <li>
                <filter>
                    <categories>
                        <li>Corpses</li>
                    </categories>
                </filter>
                <count>1</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Plasteel</li>
                    </thingDefs>
                </filter>
                <count>50</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>Corpse_PM_Probe</li>
                <li>Corpse_PM_Sentry</li>
                <li>Corpse_PM_Sentinel</li>
                <li>Corpse_PM_Energizer</li>
                <li>Corpse_PM_FellowProbe</li>
                <li>Corpse_PM_Servitor</li>
            </thingDefs>
        </fixedIngredientFilter>
    </RecipeDef>

