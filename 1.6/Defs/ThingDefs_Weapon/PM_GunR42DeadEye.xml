<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <ThingDef ParentName="BaseBullet">
        <defName>PM_Bullet_R42_Short</defName>
        <label>8×80 mm tungsten-rhenium rail slug</label>
        <thingClass>ProtossMech.Bullet_RailDeadEye</thingClass>
        <graphicData>
            <texPath>Things/Weapon/RailGun/R42Projectile</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <projectile>
            <damageDef>Bullet</damageDef>
            <damageAmountBase>20</damageAmountBase>
            <speed>240</speed>
            <armorPenetrationBase>1.26</armorPenetrationBase>
            <stoppingPower>2.2</stoppingPower>
        </projectile>
    </ThingDef>

    <ThingDef ParentName="BaseBullet">
        <defName>PM_Bullet_RailDeadEye</defName>
        <label>8×100 mm tungsten-rhenium rail slug</label>
        <thingClass>ProtossMech.Bullet_RailDeadEye</thingClass>
        <graphicData>
            <texPath>Things/Weapon/RailGun/R42Projectile</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <projectile>
            <damageDef>Bullet</damageDef>
            <damageAmountBase>20</damageAmountBase>
            <speed>240</speed>
            <armorPenetrationBase>1.58</armorPenetrationBase>
            <stoppingPower>2.2</stoppingPower>
        </projectile>
    </ThingDef>

    <ThingDef ParentName="BaseBullet">
        <defName>PM_Bullet_R42_Long</defName>
        <label>8×120 mm tungsten-rhenium rail slug</label>
        <thingClass>ProtossMech.Bullet_RailDeadEye</thingClass>
        <graphicData>
            <texPath>Things/Weapon/RailGun/R42Projectile</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <projectile>
            <damageDef>Bullet</damageDef>
