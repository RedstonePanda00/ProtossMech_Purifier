<?xml version="1.0" encoding="utf-8"?>

<Defs>
    <AbilityDef>
        <defName>MechForceFieldWall</defName>
        <label>project Force Field Wall</label>
        <description>Projects a 3x3 Force Field Wall structures.</description>
        <iconPath>Things/Abilities/Force_field</iconPath>
        <cooldownTicksRange>300</cooldownTicksRange>
        <hostile>false</hostile>
        <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>

        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <warmupTime>0.5</warmupTime>
            <range>20</range>
            <targetParams>
                <canTargetLocations>true</canTargetLocations>
            </targetParams>
        </verbProperties>

        <comps>
            <li Class="ProtossMech.CompProperties_PlacingBuilding">
                <thingToSpawn>ForceFieldWall</thingToSpawn>
                <pattern>
                    <li>(-1, -1)</li>
                    <li>(0, -1)</li>
                    <li>(1, -1)</li>
                    <li>(-1, 0)</li>
                    <li>(0, 0)</li>
                    <li>(1, 0)</li>
                    <li>(-1, 1)</li>
                    <li>(0, 1)</li>
                    <li>(1, 1)</li>
                </pattern>
                <fleckDefOnSpawn>DustPuffThick</fleckDefOnSpawn>
            </li>
        </comps>
    </AbilityDef>

    <AbilityDef>
        <defName>PM_GuardianShield</defName>
        <label>Guardian Shield</label>
        <description>activate shield generator, which can block projectile.</description>
        <iconPath>Things/Abilities/Guardian_shield</iconPath>
        <cooldownTicksRange>300</cooldownTicksRange>
        <hostile>false</hostile>
        <targetRequired>false</targetRequired>
        <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <warmupTime>0</warmupTime>
            <targetParams>
                <canTargetSelf>true</canTargetSelf>
            </targetParams>
        </verbProperties>
        <comps>
            <li Class="ProtossMech.CompProperties_ApplyHediff">
                <targetType>Self</targetType>
                <hediffDefNames>
                    <li>PM_Hediff_GuardianShieldActive</li>
                </hediffDefNames>
            </li>
        </comps>
    </AbilityDef>

    <AbilityDef>
        <defName>PM_PhaseMode</defName>
        <label>Phase mode</label>
        <description>Enter phase mode. While phased, this unit cannot move but projects a stronger shield field.</description>
        <iconPath>Things/Abilities/Guardian_shield</iconPath>
        <cooldownTicksRange>60</cooldownTicksRange>
        <hostile>false</hostile>
        <targetRequired>false</targetRequired>
        <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <warmupTime>0</warmupTime>
            <targetParams>
                <canTargetSelf>true</canTargetSelf>
            </targetParams>
        </verbProperties>
        <comps>
            <li Class="ProtossMech.CompProperties_ToggleHediff">
                <hediffDefName>PM_Hediff_EnergizerPhaseMode</hediffDefName>
            </li>
        </comps>
    </AbilityDef>

    <AbilityDef>
        <defName>MechChronoBeam</defName>
        <label>Chrono Beam</label>
        <description>The beam that can speed up the time flow of target.</description>
        <iconPath>Things/Abilities/ChronoBeam</iconPath>
        <cooldownTicksRange>60</cooldownTicksRange>
        <hostile>false</hostile>
        <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <range>30</range>
            <warmupTime>0.5</warmupTime>
            <requireLineOfSight>false</requireLineOfSight>
            <targetParams>
                <canTargetLocations>false</canTargetLocations>
                <canTargetSelf>false</canTargetSelf>
                <canTargetPawns>true</canTargetPawns>
            </targetParams>
        </verbProperties>
        <comps>
            <li Class="ProtossMech.CompProperties_ApplyHediff">
                <targetType>Target</targetType>

                <hediffDefNames>
                    <li>Hediff_TemporalSurge</li>
                </hediffDefNames>

                <projectileDefName>PMP_ChronoBeamProjectile</projectileDefName>
            </li>
        </comps>
    </AbilityDef>

    <AbilityDef>
        <defName>PM_HavocTargetLock</defName>
        <label>target lock</label>
        <description>Lock onto a hostile target. While locked, that target takes increased damage from all sources. Only one target at a time.</description>
        <iconPath>Things/Abilities/Force_field</iconPath>
        <cooldownTicksRange>120</cooldownTicksRange>
        <hostile>true</hostile>
        <casterMustBeCapableOfViolence>true</casterMustBeCapableOfViolence>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <warmupTime>0.25</warmupTime>
            <range>50</range>
            <requireLineOfSight>true</requireLineOfSight>
            <targetParams>
                <canTargetPawns>true</canTargetPawns>
                <canTargetSelf>false</canTargetSelf>
                <canTargetLocations>false</canTargetLocations>
            </targetParams>
        </verbProperties>
        <comps>
            <li Class="ProtossMech.CompProperties_AbilityTargetLock" />
        </comps>
        <modExtensions>
            <li Class="ProtossMech.AbilityExtension_TargetLockSettings">
                <maxLockRangeCells>50</maxLockRangeCells>
                <incomingDamageMultiplier>1.3</incomingDamageMultiplier>
            </li>
        </modExtensions>
    </AbilityDef>

    <AbilityDef>
        <defName>LegionnaireJump</defName>
        <label>Engage</label>
        <description>Jump to a distant location using special ultrafast mechanoid muscles.</description>
        <iconPath>Things/Abilities/KaldalisIntercept</iconPath>
        <cooldownTicksRange>300</cooldownTicksRange>
        <hostile>false</hostile>
        <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
        <verbProperties>
            <verbClass>Verb_CastAbilityJump</verbClass>
            <requireLineOfSight>false</requireLineOfSight>
            <label>jump</label>
            <violent>false</violent>
            <forceNormalTimeSpeed>false</forceNormalTimeSpeed>
            <warmupTime>0</warmupTime>
            <minRange>0</minRange>
            <range>20</range>
            <requireLineOfSight>true</requireLineOfSight>
            <soundCast>Longjump_Jump</soundCast>
            <soundLanding>Longjump_Land</soundLanding>
            <flyWithCarriedThing>false</flyWithCarriedThing>
            <targetParams>
                <canTargetLocations>true</canTargetLocations>
                <canTargetPawns>false</canTargetPawns>
                <canTargetBuildings>false</canTargetBuildings>
            </targetParams>
        </verbProperties>
    </AbilityDef>

    <!-- Umbra Skip: teleport to cell (through walls), then 45 execute damage to enemies at destination -->
    <AbilityDef>
        <defName>PMP_UmbraSkip</defName>
        <label>Skip</label>
        <description>Phase to the targeted location, ignoring walls. Upon arrival, deal 45 execute damage to hostile pawns in a small radius.</description>
        <iconPath>UI/Abilities/Skip</iconPath>
        <cooldownTicksRange>300</cooldownTicksRange>
        <groupAbility>true</groupAbility>
        <hostile>false</hostile>
        <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <requireLineOfSight>false</requireLineOfSight>
            <range>25</range>
            <warmupTime>0.25</warmupTime>
            <targetParams>
                <canTargetLocations>true</canTargetLocations>
                <canTargetPawns>false</canTargetPawns>
                <canTargetBuildings>false</canTargetBuildings>
            </targetParams>
        </verbProperties>
        <comps>
            <li Class="ProtossMech.CompProperties_UmbraSkip">
                <damageAmount>45</damageAmount>
                <damageRadius>2.9</damageRadius>
                <damageDef>ExecutionCut</damageDef>
            </li>
        </comps>
    </AbilityDef>

    <AbilityDef>
        <defName>PMP_UmbraTripleStrike</defName>
        <label>Triple strike</label>
        <description>Lock onto a hostile target and, as soon as the ability finishes warming up, hit it with three anti-armor shock beams (85 damage each to the same body part, default torso). Range and line of sight are checked only when casting; after that, strikes continue even if the target runs away or breaks LOS. Each beam uses the same visual as the Khaydarin monolith. Delays apply only between the 1st and 2nd and between the 2nd and 3rd strike (10 ticks). If the target dies, the nearest hostile pawn in cast range is chosen for remaining hits, otherwise a hostile building. Cannot be recast until the combo finishes. Buildings take normal damage.</description>
        <iconPath>Things/Abilities/ChronoBeam</iconPath>
        <cooldownTicksRange>600</cooldownTicksRange>
        <groupAbility>true</groupAbility>
        <hostile>true</hostile>
        <casterMustBeCapableOfViolence>true</casterMustBeCapableOfViolence>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <requireLineOfSight>true</requireLineOfSight>
            <range>40</range>
            <warmupTime>1.5</warmupTime>
            <targetParams>
                <canTargetLocations>false</canTargetLocations>
                <canTargetSelf>false</canTargetSelf>
                <canTargetPawns>true</canTargetPawns>
                <canTargetBuildings>true</canTargetBuildings>
            </targetParams>
        </verbProperties>
        <comps>
            <li Class="ProtossMech.CompProperties_UmbraTripleStrike" />
        </comps>
    </AbilityDef>

    <AbilityDef>
        <defName>MechCharge</defName>
        <label>charge</label>
        <description>Speed up in several seconds.</description>
        <iconPath>Things/Abilities/Charge</iconPath>
        <cooldownTicksRange>1800</cooldownTicksRange>
        <hostile>false</hostile>
        <groupAbility>true</groupAbility>
        <targetRequired>false</targetRequired>
        <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <warmupTime>0</warmupTime>
            <nonInterruptingSelfCast>true</nonInterruptingSelfCast>
            <targetParams>
                <canTargetSelf>true</canTargetSelf>
            </targetParams>
        </verbProperties>
        <comps>
            <li Class="ProtossMech.CompProperties_ApplyHediff">
                <targetType>Self</targetType>
                <hediffDefNames>
                    <li>Hediff_Charging</li>
                </hediffDefNames>
            </li>
        </comps>
    </AbilityDef>

    <AbilityDef>
        <defName>Warp_Pylon</defName>
        <label>Warp Pylon</label>
        <iconPath>Things/Abilities/WarpPylon</iconPath>
        <cooldownTicksRange>300</cooldownTicksRange>
        <hostile>false</hostile>
        <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <range>1</range>
            <targetParams>
                <canTargetLocations>true</canTargetLocations>
            </targetParams>
        </verbProperties>

        <comps>
            <li Class="ProtossMech.CompProperties_PlacingBuilding">
                <thingToSpawn>WarpBeacon_Pylon</thingToSpawn>
            </li>
        </comps>
    </AbilityDef>

    <AbilityDef>
        <defName>Warp_Photon</defName>
        <label>Warp Photon</label>
        <iconPath>Things/Abilities/WarpPhoton</iconPath>
        <cooldownTicksRange>300</cooldownTicksRange>
        <hostile>false</hostile>
        <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>

        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <range>1</range>
            <targetParams>
                <canTargetLocations>true</canTargetLocations>
            </targetParams>
        </verbProperties>

        <comps>
            <li Class="ProtossMech.CompProperties_PlacingBuilding">
                <thingToSpawn>WarpBeacon_Photon</thingToSpawn>
            </li>
        </comps>
    </AbilityDef>

    <AbilityDef>
        <defName>OverchargeAllPylons</defName>
        <label>Overcharge All Pylons</label>
        <iconPath>Things/Abilities/PylonOvercharge</iconPath>
        <hostile>false</hostile>
        <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
        <targetRequired>false</targetRequired>
        <verbProperties>
            <verbClass>ProtossMech.Verb_CastAbilityOverchargeAllPylons</verbClass>
            <range>999</range>
        </verbProperties>
        <cooldownTicksRange>3600</cooldownTicksRange>
    </AbilityDef>

    <AbilityDef>
        <defName>PMP_RestoreShield</defName>
        <label>Barrier</label>
        <description>Instantly restores the caster's Protoss shield to its maximum energy level.</description>
        <iconPath>Things/Abilities/Barrier</iconPath>
        <cooldownTicksRange>7200</cooldownTicksRange>
        <charges>2</charges>
        <cooldownPerCharge>true</cooldownPerCharge>
        <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
        <targetRequired>false</targetRequired>
        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <warmupTime>0</warmupTime>
            <targetParams>
                <canTargetSelf>true</canTargetSelf>
                <canTargetLocations>false</canTargetLocations>
            </targetParams>
        </verbProperties>

        <comps>
            <li Class="ProtossMech.CompProperties_AbilityRestoreShield" />
        </comps>

    </AbilityDef>

    <AbilityDef>
        <defName>PMP_SummonNova</defName>
        <label>Summon Purification Nova</label>
        <description>Summon Purification Nova to the location.</description>
        <iconPath>Things/Abilities/PurificationNova</iconPath>
        <cooldownTicksRange>1260</cooldownTicksRange>
        <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>

        <verbProperties>
            <verbClass>Verb_CastAbility</verbClass>
            <requireLineOfSight>false</requireLineOfSight>
            <warmupTime>0</warmupTime>
            <range>30.0</range>
            <targetParams>
                <canTargetLocations>true</canTargetLocations>
                <canTargetSelf>false</canTargetSelf>
                <canTargetPawns>false</canTargetPawns>
                <canTargetBuildings>false</canTargetBuildings>
            </targetParams>
        </verbProperties>

        <comps>
            <li Class="ProtossMech.CompProperties_SpawnAndGo">
                <thingDefToSpawn>PMP_PurificationNova</thingDefToSpawn>
            </li>
        </comps>

    </AbilityDef>

</Defs>