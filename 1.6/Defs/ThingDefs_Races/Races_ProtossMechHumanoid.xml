<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!-- Legionnaire -->
  <ThingDef ParentName="ProtossMechanoid">
    <defName>PMP_Legionnaire</defName>
    <label>Legionnaire</label>
    <description>Legionnaires are among the earliest products of the Purifier Program. Their neural patterns were replicated from the consciousness of the greatest Templar warriors of antiquity. \n\n Following their activation, the Legionnaires participated in numerous brutal campaigns before their involvement in the Great Purifier Rebellion—a conflict that inflicted grievous losses upon the Protoss Empire and led to the indefinite deactivation of the entire Purifier Program. Despite this history, they remain invaluable soldiers, each possessing tens of thousands of years of combat experience.</description>
    <statBases>
      <BandwidthCost>3</BandwidthCost>
      <ArmorRating_Blunt>1.5</ArmorRating_Blunt>
      <ArmorRating_Sharp>1.5</ArmorRating_Sharp>
      <MoveSpeed>6.5</MoveSpeed>
      <IncomingDamageFactor>0.5</IncomingDamageFactor>
      <RangedCooldownFactor>0.5</RangedCooldownFactor>
      <AimingDelayFactor>0.5</AimingDelayFactor>
      <ShootingAccuracyPawn>12</ShootingAccuracyPawn>
      <ShootingAccuracyFactor_Medium>1.5</ShootingAccuracyFactor_Medium>
      <ShootingAccuracyFactor_Long>1.5</ShootingAccuracyFactor_Long>
    </statBases>
    <race>
      <body>PMP_HumanoidBody</body>
      <baseBodySize>2</baseBodySize>
      <mechEnabledWorkTypes>
        <li>Hauling</li>
        <li>Cleaning</li>
        <li>Hunting</li>
        <li>Firefighter</li>
      </mechEnabledWorkTypes>
      <soundMeleeHitPawn>Pawn_Melee_MechanoidSlash_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_MechanoidSlash_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_MechanoidSlash_Miss</soundMeleeMiss>
      <lifeStageAges>
        <li>
          <def>MechanoidFullyFormed</def>
          <minAge>0</minAge>
          <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
          <soundCall>Pawn_Mech_Scyther_Call</soundCall>
        </li>
      </lifeStageAges>
      <baseHealthScale>5.0</baseHealthScale>
    </race>
    <butcherProducts>
      <PM_Adanium>100</PM_Adanium>
    </butcherProducts>

    <tools>
      <li>
        <label>left Energy Blade</label>
        <capacities>
          <li>Cut</li>
          <li>Stab</li>
        </capacities>
        <power>16</power>
        <cooldownTime>1.0</cooldownTime>
        <armorPenetration>1.5</armorPenetration>
      </li>
      <li>
        <label>right Energy Blade</label>
        <capacities>
          <li>Cut</li>
          <li>Stab</li>
        </capacities>
        <power>16</power>
        <cooldownTime>1.0</cooldownTime>
        <armorPenetration>1.5</armorPenetration>
      </li>
    </tools>

    <comps>
      <li Class="ProtossMech.CompProperties_ProtossMechShield">
        <energyMax>100</energyMax>
        <energyGainPerTick>0.25</energyGainPerTick>
        <ticksToBeginRecharge>600</ticksToBeginRecharge>
        <minDrawSize>0</minDrawSize>
        <maxDrawSize>2</maxDrawSize>
      </li>
      <li Class="ProtossMech.CompProperties_PurifierReconstruct">
        <cooldownTicks>3600</cooldownTicks>
        <reconstructHediff>Hediff_Reconstruct</reconstructHediff>
      </li>
      <li Class="RsPandaLibrary.CompProperties_EquippableMechanoid" />
    </comps>

    <modExtensions>
        <li Class="RsPandaLibrary.Compatibility.RimTalk.RimTalkPersonaExtension">
            <personaKeys>
                <li>Protoss_Persona_Legionnaire_Conclave</li>
                <li>Protoss_Persona_Legionnaire_Fleet</li>
                <li>Protoss_Persona_Legionnaire_Vanguard</li>
            </personaKeys>
            <chattiness>0.5</chattiness>
        </li>
    </modExtensions>
  </ThingDef>

  <PawnKindDef ParentName="ProtossMechanoidKind">
    <defName>PMP_Legionnaire</defName>
    <label>Legionnaire</label>
    <race>PMP_Legionnaire</race>
    <combatPower>42</combatPower>
    <allowInMechClusters>false</allowInMechClusters>
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Mechanoid/Legionnaire</texPath>
          <shaderType>Cutout</shaderType>
          <drawSize>2.0</drawSize>
        </bodyGraphicData>
      </li>
    </lifeStages>
    <abilities>
      <li>MechCharge</li>
    </abilities>
  </PawnKindDef>

  <!-- Sentinel -->
  <ThingDef ParentName="ProtossMechanoid">
    <defName>PMP_Sentinel</defName>
    <label>Sentinel</label>
    <description>The Sentinels originated from an offshoot of the Purifier Project, employing positronic AI as an ethical alternative to digital neural patterns transfer. Even if destroyed, they can be rapidly reassembled by reconstruction drones.</description>
    <statBases>
      <BandwidthCost>2</BandwidthCost>
      <ArmorRating_Blunt>0.7</ArmorRating_Blunt>
      <ArmorRating_Sharp>0.7</ArmorRating_Sharp>
      <MoveSpeed>6.0</MoveSpeed>
    </statBases>
    <race>
      <body>PMP_HumanoidBody</body>
      <baseBodySize>1</baseBodySize>
      <mechEnabledWorkTypes>
        <li>Hauling</li>
        <li>Cleaning</li>
        <li>Hunting</li>
        <li>Firefighter</li>
      </mechEnabledWorkTypes>
      <soundMeleeHitPawn>Pawn_Melee_MechanoidSlash_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_MechanoidSlash_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_MechanoidSlash_Miss</soundMeleeMiss>
      <lifeStageAges>
        <li>
          <def>MechanoidFullyFormed</def>
          <minAge>0</minAge>
          <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
          <soundCall>Pawn_Mech_Scyther_Call</soundCall>
        </li>
      </lifeStageAges>
      <baseHealthScale>2.5</baseHealthScale>
    </race>
    <butcherProducts>
      <Plasteel>25</Plasteel>
    </butcherProducts>

    <tools>
      <li>
        <label>left Energy Blade</label>
        <capacities>
          <li>Cut</li>
          <li>Stab</li>
        </capacities>
        <power>8</power>
        <cooldownTime>1.0</cooldownTime>
        <armorPenetration>0.75</armorPenetration>
      </li>
      <li>
        <label>right Energy Blade</label>
        <capacities>
          <li>Cut</li>
          <li>Stab</li>
        </capacities>
        <power>8</power>
        <cooldownTime>1.0</cooldownTime>
        <armorPenetration>0.75</armorPenetration>
      </li>
    </tools>

    <comps>
      <li Class="ProtossMech.CompProperties_ProtossMechShield">
        <energyMax>50</energyMax>
        <energyGainPerTick>0.25</energyGainPerTick>
        <ticksToBeginRecharge>600</ticksToBeginRecharge>
        <minDrawSize>0</minDrawSize>
        <maxDrawSize>2</maxDrawSize>
      </li>
      <li Class="ProtossMech.CompProperties_PurifierReconstruct">
        <cooldownTicks>3600</cooldownTicks>
        <reconstructHediff>Hediff_Reconstruct</reconstructHediff>
      </li>
      <li Class="RsPandaLibrary.CompProperties_EquippableMechanoid" />
    </comps>
    <modExtensions>
        <li Class="RsPandaLibrary.Compatibility.RimTalk.RimTalkPersonaExtension">
            <personaKeys>
                <li>Protoss_Persona_Sentinel</li>
            </personaKeys>
            <chattiness>0.25</chattiness>
        </li>
    </modExtensions>
  </ThingDef>

  <PawnKindDef ParentName="ProtossMechanoidKind">
    <defName>PMP_Sentinel</defName>
    <label>Sentinel</label>
    <race>PMP_Sentinel</race>
    <combatPower>42</combatPower>
    <allowInMechClusters>false</allowInMechClusters>
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Mechanoid/Sentinel</texPath>
          <shaderType>Cutout</shaderType>
          <drawSize>1.5</drawSize>
        </bodyGraphicData>
      </li>
    </lifeStages>
    <abilities>
      <li>MechCharge</li>
    </abilities>
  </PawnKindDef>

  <!-- Umbra -->
  <ThingDef ParentName="ProtossMechanoid">
    <defName>PMP_Umbra</defName>
    <label>Umbra</label>
    <description>The Umbra is the Purifier iteration of the Dark Templar. Discarding the reliance on optical camouflage, its chassis is a radical design: a cohesive swarm of millions of micro-drones linked by a localized neural net. Utilizing micro-predictive evasion, it allows projectiles to pass harmlessly through its shifting form before delivering lethal strikes with condensed warp blades.</description>
    <statBases>
      <BandwidthCost>2</BandwidthCost>
      <ArmorRating_Blunt>1.5</ArmorRating_Blunt>
      <ArmorRating_Sharp>1.5</ArmorRating_Sharp>
      <MoveSpeed>3.9</MoveSpeed>
      <MeleeHitChance>100.0</MeleeHitChance>
      <IncomingDamageFactor>0.25</IncomingDamageFactor>
      <MeleeDodgeChance>95</MeleeDodgeChance>
    </statBases>
    <race>
      <body>PMP_HumanoidBody</body>
      <baseBodySize>1.2</baseBodySize>
      <mechEnabledWorkTypes>
        <li>Hunting</li>
      </mechEnabledWorkTypes>
      <soundMeleeHitPawn>Pawn_Melee_MechanoidSlash_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_MechanoidSlash_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_MechanoidSlash_Miss</soundMeleeMiss>
      <lifeStageAges>
        <li>
          <def>MechanoidFullyFormed</def>
          <minAge>0</minAge>
          <soundWounded>Pawn_Mech_Scyther_Wounded</soundWounded>
          <soundDeath>Pawn_Mech_Scyther_Death</soundDeath>
          <soundCall>Pawn_Mech_Scyther_Call</soundCall>
        </li>
      </lifeStageAges>
      <baseHealthScale>2.0</baseHealthScale>
    </race>
    <butcherProducts>
      <PM_Adanium>125</PM_Adanium>
    </butcherProducts>

    <tools>
      <li>
        <label>Warp blade</label>
        <capacities>
          <li>Cut</li>
          <li>Stab</li>
        </capacities>
        <power>45</power>
        <cooldownTime>1.2</cooldownTime>
        <armorPenetration>2.0</armorPenetration>
      </li>
    </tools>

    <comps>
      <li Class="ProtossMech.CompProperties_ProtossMechShield">
        <energyMax>80</energyMax>
        <energyGainPerTick>0.25</energyGainPerTick>
        <ticksToBeginRecharge>400</ticksToBeginRecharge>
        <minDrawSize>0</minDrawSize>
        <maxDrawSize>1.5</maxDrawSize>
      </li>
      <li Class="ProtossMech.CompProperties_PurifierReconstruct">
        <cooldownTicks>3600</cooldownTicks>
        <reconstructHediff>Hediff_Reconstruct</reconstructHediff>
      </li>
      <li Class="ProtossMech.CompProperties_UmbraWarpBladeRenderer" />
    </comps>

    <modExtensions>
        <li Class="RsPandaLibrary.Compatibility.RimTalk.RimTalkPersonaExtension">
            <personaKeys>
                <li>Protoss_Persona_Umbra</li>
            </personaKeys>
            <chattiness>0.15</chattiness>
        </li>
    </modExtensions>
  </ThingDef>

  <PawnKindDef ParentName="ProtossMechanoidKind">
    <defName>PMP_Umbra</defName>
    <label>Umbra</label>
    <race>PMP_Umbra</race>
    <combatPower>42</combatPower>
    <allowInMechClusters>false</allowInMechClusters>
    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Things/Pawn/Mechanoid/Umbra</texPath>
          <shaderType>Transparent</shaderType>
          <drawSize>1.5</drawSize>
        </bodyGraphicData>
      </li>
    </lifeStages>
    <abilities>
      <li>PMP_UmbraSkip</li>
    </abilities>
  </PawnKindDef>

</Defs>