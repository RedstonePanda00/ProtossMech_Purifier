<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_Common_DarkTemplarSuppressor</defName>
        <label>DarkTemplar integrated suppressor</label>
        <description>An integrated suppressor that absorbs the acoustic shock of firing and recovers a portion of projectile-drive kinetic waste, eliminating the weapon report while slightly improving ballistic efficiency.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
            <li>PM_GunSmith_B25Bulwark</li>
            <li>PM_GunSmith_C31Tempest</li>
        </compatiblePlatforms>
        <slotId>Muzzle</slotId>
        <texPath>Things/Weapon/C7Templar/C7_Muzzle_01</texPath>
        <relativeToSlotId>Barrel</relativeToSlotId>
        <rangeOffset>2</rangeOffset>
        <projectileSpeedFactor>1.05</projectileSpeedFactor>
        <silencesShotSound>true</silencesShotSound>
        <statOffsets>
            <Mass>0.2</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_Common_MarksmanOptic</defName>
        <label>marksman optic</label>
        <description>A 4x/6x/8x variable-power optic with infrared thermal imaging. It improves medium- and long-range fire through smoke at the cost of close-range handling, acquisition time, and weight.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_R42</li>
            <li>PM_GunSmith_C31Tempest</li>
            <li>PM_GunSmith_C19Dragoon</li>
            <li>PM_GunSmith_B25Bulwark</li>
        </compatiblePlatforms>
        <slotId>Optic</slotId>
        <texPath>Things/Weapon/C7Templar/C7_Optic_02</texPath>
        <ignoresSmokeAccuracy>true</ignoresSmokeAccuracy>
        <warmupTimeOffset>0.10</warmupTimeOffset>
        <statOffsets>
            <AccuracyTouch>-0.04</AccuracyTouch>
            <AccuracyShort>-0.02</AccuracyShort>
            <AccuracyMedium>0.06</AccuracyMedium>
            <AccuracyLong>0.10</AccuracyLong>
            <Mass>0.3</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_Common_Printer_MagFactory</defName>
        <label>Printer magazine factory</label>
        <description>A compact micro-fabricator magazine. After the weapon has stopped firing for one second, it prints fresh rounds directly into the magazine at a steady rate until full. It does not consume carried ammunition and suppresses passive reload attempts when empty.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
        </compatiblePlatforms>
        <slotId>Magazine</slotId>
        <texPath>Things/Weapon/Common/Printer_MagFactory</texPath>
        <iconPath>Things/Weapon/Common/Printer_MagFactory</iconPath>
        <requiresCombatExtended>true</requiresCombatExtended>
        <ceProvidesMagazineSize>true</ceProvidesMagazineSize>
        <ceMagazineSize>45</ceMagazineSize>
        <ceAmmoPrinterDelayTicks>60</ceAmmoPrinterDelayTicks>
        <ceAmmoPrinterIntervalTicks>60</ceAmmoPrinterIntervalTicks>
        <ceAmmoPrinterRoundsPerInterval>10</ceAmmoPrinterRoundsPerInterval>
        <ceSuppressPassiveReloadWhenEmpty>true</ceSuppressPassiveReloadWhenEmpty>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_Common_IronSight_Rear_Raised</defName>
        <label>raised rear iron sight</label>
        <description>Hidden visual default for raised mechanical rear sights.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
            <li>PM_GunSmith_B25Bulwark</li>
            <li>PM_GunSmith_B9Zealot</li>
            <li>PM_GunSmith_B12Vanguard</li>
        </compatiblePlatforms>
        <slotId>RearIronSight</slotId>
        <texPath>Things/Weapon/Common/IronSight</texPath>
        <selectable>false</selectable>
        <drawOverBody>true</drawOverBody>
        <drawOrder>-5</drawOrder>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_Common_IronSight_Front_Raised</defName>
        <label>raised front iron sight</label>
        <description>Hidden visual default for raised mechanical front sights.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
            <li>PM_GunSmith_B25Bulwark</li>
            <li>PM_GunSmith_B9Zealot</li>
            <li>PM_GunSmith_B12Vanguard</li>
        </compatiblePlatforms>
        <slotId>FrontIronSight</slotId>
        <texPath>Things/Weapon/Common/IronSight</texPath>
        <selectable>false</selectable>
        <drawOverBody>true</drawOverBody>
        <drawOrder>-5</drawOrder>
        <relativeToSlotId>Barrel</relativeToSlotId>
        <localAttachmentOffset>(-0.18, -0.10)</localAttachmentOffset>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_Common_IronSight_Rear_Folded</defName>
        <label>folded rear iron sight</label>
        <description>Hidden visual default for folded mechanical rear sights.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
            <li>PM_GunSmith_B25Bulwark</li>
            <li>PM_GunSmith_B9Zealot</li>
            <li>PM_GunSmith_B12Vanguard</li>
        </compatiblePlatforms>
        <slotId>RearIronSight</slotId>
        <texPath>Things/Weapon/Common/IronSight_folded</texPath>
        <selectable>false</selectable>
        <drawOverBody>true</drawOverBody>
        <drawOrder>-5</drawOrder>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_Common_IronSight_Front_Folded</defName>
        <label>folded front iron sight</label>
        <description>Hidden visual default for folded mechanical front sights.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
            <li>PM_GunSmith_B25Bulwark</li>
            <li>PM_GunSmith_B9Zealot</li>
            <li>PM_GunSmith_B12Vanguard</li>
        </compatiblePlatforms>
        <slotId>FrontIronSight</slotId>
        <texPath>Things/Weapon/Common/IronSight_folded</texPath>
        <selectable>false</selectable>
        <drawOverBody>true</drawOverBody>
        <drawOrder>-5</drawOrder>
        <relativeToSlotId>Barrel</relativeToSlotId>
        <localAttachmentOffset>(-0.18, -0.10)</localAttachmentOffset>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_Common_BoxLaser</defName>
        <label>box tactical laser</label>
        <description>A compact enclosed laser module that permits a stable tactical stance without obstructing the weapon. It improves target acquisition and shot placement at close and medium range without imposing a handling penalty.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
            <li>PM_GunSmith_B25Bulwark</li>
            <li>PM_GunSmith_B9Zealot</li>
            <li>PM_GunSmith_B12Vanguard</li>
        </compatiblePlatforms>
        <slotId>Laser</slotId>
        <texPath>Things/Weapon/Common/Laser_01</texPath>
        <relativeToSlotId>Barrel</relativeToSlotId>
        <drawOverBody>true</drawOverBody>
        <drawOrder>10</drawOrder>
        <ceShotSpreadFactor>0.92</ceShotSpreadFactor>
        <ceSwayFactor>0.92</ceSwayFactor>
        <statOffsets>
            <AccuracyTouch>0.04</AccuracyTouch>
            <AccuracyShort>0.07</AccuracyShort>
            <AccuracyMedium>0.04</AccuracyMedium>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_Common_MuzzleBrake_01</defName>
        <label>vented muzzle brake</label>
        <description>A multi-baffle muzzle brake that rapidly vents propellant heat and counters vertical climb. Its improved recovery is represented by shorter firing cooldown and more consistent long-range fire.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
            <li>PM_GunSmith_B25Bulwark</li>
            <li>PM_GunSmith_C31Tempest</li>
        </compatiblePlatforms>
        <slotId>Muzzle</slotId>
        <texPath>Things/Weapon/Common/MuzzleBrake_01</texPath>
        <relativeToSlotId>Barrel</relativeToSlotId>
        <ceRecoilFactor>0.75</ceRecoilFactor>
        <statOffsets>
            <AccuracyLong>0.06</AccuracyLong>
            <RangedWeapon_Cooldown>-0.12</RangedWeapon_Cooldown>
            <Mass>0.12</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_Common_UB_FrontGrip01</defName>
        <label>light triangular foregrip</label>
        <description>A light triangular foregrip that braces the support hand without burdening the weapon, improving ergonomics and bringing the gun on target faster.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
            <li>PM_GunSmith_B25Bulwark</li>
        </compatiblePlatforms>
        <slotId>UnderBarrel</slotId>
        <texPath>Things/Weapon/Common/UB_FrontGrip01</texPath>
        <relativeToSlotId>Barrel</relativeToSlotId>
        <warmupTimeOffset>-0.12</warmupTimeOffset>
        <statOffsets>
            <Mass>0.05</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_Common_UB_JetGrip</defName>
        <label>solarite vector-thrust grip</label>
        <description>A solarite-cell-powered underbarrel grip with two vectoring nozzles. Its thrust controller cancels recoil completely and continuously stabilizes the weapon, raising every range band to whichever accuracy band is currently highest.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
            <li>PM_GunSmith_B25Bulwark</li>
        </compatiblePlatforms>
        <slotId>UnderBarrel</slotId>
        <texPath>Things/Weapon/Common/UB_JetGrip</texPath>
        <relativeToSlotId>Barrel</relativeToSlotId>
        <equalizeAccuracyToBest>true</equalizeAccuracyToBest>
        <ceEliminatesRecoil>true</ceEliminatesRecoil>
        <warmupTimeOffset>-0.08</warmupTimeOffset>
        <statOffsets>
            <Mass>0.35</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_Common_UB_Launcher_HE</defName>
        <label>underbarrel fragmentation launcher</label>
        <description>A dedicated underbarrel launcher controlled through its own firing gizmo. It launches a single fragmentation grenade at the selected location.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
            <li>PM_GunSmith_B25Bulwark</li>
        </compatiblePlatforms>
        <slotId>UnderBarrel</slotId>
        <texPath>Things/Weapon/Common/UB_Laucher_HE</texPath>
        <relativeToSlotId>Barrel</relativeToSlotId>
        <workerClass>ProtossMech.GunSmith.GunSmithPartWorker_UnderbarrelHE</workerClass>
        <statOffsets>
            <Mass>1.0</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_Common_UB_Launcher_Shotgun</defName>
        <label>underbarrel cluster shotgun</label>
        <description>A compact underbarrel scatter launcher controlled through its own firing gizmo. One trigger command releases a twelve-pellet cluster across the selected target area.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
            <li>PM_GunSmith_B25Bulwark</li>
        </compatiblePlatforms>
        <slotId>UnderBarrel</slotId>
        <texPath>Things/Weapon/Common/UB_Laucher_Shotgun</texPath>
        <relativeToSlotId>Barrel</relativeToSlotId>
        <workerClass>ProtossMech.GunSmith.GunSmithPartWorker_UnderbarrelShotgun</workerClass>
        <statOffsets>
            <Mass>0.9</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_Common_UB_Launcher_LaserCannon</defName>
        <label>underbarrel continuous laser cannon</label>
        <description>A sustained-fire laser cannon governed by an independent thermal worker. Firing gradually raises heat while releasing the trigger cools it toward zero. It may be restarted at any heat below 100%; reaching full heat locks the system until completely cooled and discharges a final Biotech hellsphere shot at the last target.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
            <li>PM_GunSmith_B25Bulwark</li>
        </compatiblePlatforms>
        <slotId>UnderBarrel</slotId>
        <texPath>Things/Weapon/Common/UB_Laucher_LaserCannon</texPath>
        <relativeToSlotId>Barrel</relativeToSlotId>
        <workerClass>ProtossMech.GunSmith.GunSmithPartWorker_UnderbarrelLaserCannon</workerClass>
        <statOffsets>
            <Mass>1.5</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_Common_ViperSight</defName>
        <label>"Viper" virtual sight</label>
        <description>A lensless virtual sight whose frameless electronic reticle floats above the weapon. Its unobstructed picture remains clear at every range, while the extremely light emitter markedly improves handling and reveals cloaked targets.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_R42</li>
            <li>PM_GunSmith_C31Tempest</li>
            <li>PM_GunSmith_C19Dragoon</li>
            <li>PM_GunSmith_B25Bulwark</li>
            <li>PM_GunSmith_B9Zealot</li>
            <li>PM_GunSmith_B12Vanguard</li>
        </compatiblePlatforms>
        <slotId>Optic</slotId>
        <texPath>Things/Weapon/Common/Viper_Sight</texPath>
        <drawOverBody>true</drawOverBody>
        <drawOrder>20</drawOrder>
        <warmupTimeOffset>-0.18</warmupTimeOffset>
        <detectsCloaked>true</detectsCloaked>
        <ceShotSpreadFactor>0.90</ceShotSpreadFactor>
        <ceSwayFactor>0.80</ceSwayFactor>
        <ceSightsEfficiencyFactor>1.20</ceSightsEfficiencyFactor>
        <statOffsets>
            <AccuracyTouch>0.05</AccuracyTouch>
            <AccuracyShort>0.05</AccuracyShort>
            <AccuracyMedium>0.05</AccuracyMedium>
            <AccuracyLong>0.05</AccuracyLong>
            <Mass>0.05</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

</Defs>
