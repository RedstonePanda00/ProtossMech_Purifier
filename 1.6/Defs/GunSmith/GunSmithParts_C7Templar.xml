<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C7Templar_Barrel_01</defName>
        <label>assault coil barrel</label>
        <description>A compact multi-stage coil barrel tuned for assault fire. It extends the acceleration path without compromising the C-7's handling.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <slotId>Barrel</slotId>
        <texPath>Things/Weapon/C7Templar/C7_Barrel_01</texPath>
        <ceFullAuto>true</ceFullAuto>
        <rangeOffset>4</rangeOffset>
        <projectileDamageOffset>1</projectileDamageOffset>
        <projectileSpeedFactor>1.10</projectileSpeedFactor>
        <childSlotAnchors>
            <li>
                <slotId>Muzzle</slotId>
                <offset>(-0.4118, 0.0023)</offset>
            </li>
            <li>
                <slotId>Laser</slotId>
                <offset>(0.0407, 0.0024)</offset>
            </li>
            <li>
                <slotId>UnderBarrel</slotId>
                <offset>(0.2065, 0.1394)</offset>
            </li>
            <li>
                <slotId>FrontIronSight</slotId>
                <offset>(0.1912, -0.0096)</offset>
            </li>
        </childSlotAnchors>
        <statOffsets>
            <RangedWeapon_ArmorPenetrationMultiplier>0.05</RangedWeapon_ArmorPenetrationMultiplier>
            <AccuracyMedium>0.03</AccuracyMedium>
            <AccuracyLong>0.02</AccuracyLong>
            <Mass>0.1</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C7Templar_Barrel_02</defName>
        <label>20-inch long barrel</label>
        <description>A 20-inch extended coil barrel for deliberate C-7 fire. The longer acceleration path improves velocity, reach, penetration and long-range stability, at the cost of close handling and target acquisition speed.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <slotId>Barrel</slotId>
        <texPath>Things/Weapon/C7Templar/C7_Barrel_02</texPath>
        <ceFullAuto>true</ceFullAuto>
        <rangeOffset>8</rangeOffset>
        <warmupTimeOffset>0.15</warmupTimeOffset>
        <projectileDamageOffset>1</projectileDamageOffset>
        <projectileSpeedFactor>1.15</projectileSpeedFactor>
        <childSlotAnchors>
            <li>
                <slotId>Muzzle</slotId>
                <offset>(-0.6189, 0.0023)</offset>
            </li>
            <li>
                <slotId>Laser</slotId>
                <offset>(-0.1703, -0.0049)</offset>
            </li>
            <li>
                <slotId>UnderBarrel</slotId>
                <offset>(-0.0102, 0.1426)</offset>
            </li>
            <li>
                <slotId>FrontIronSight</slotId>
                <offset>(-0.0733, -0.0064)</offset>
            </li>
        </childSlotAnchors>
        <statOffsets>
            <RangedWeapon_ArmorPenetrationMultiplier>0.07</RangedWeapon_ArmorPenetrationMultiplier>
            <AccuracyTouch>-0.06</AccuracyTouch>
            <AccuracyShort>-0.03</AccuracyShort>
            <AccuracyMedium>0.04</AccuracyMedium>
            <AccuracyLong>0.08</AccuracyLong>
            <Mass>0.5</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C7Templar_Grip_01</defName>
        <label>C-7 Templar standard grip</label>
        <description>The C-7's standard pistol grip, providing predictable control without altering the rifle's original handling.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <slotId>Grip</slotId>
        <texPath>Things/Weapon/C7Templar/C7_Grip1</texPath>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C7Templar_Grip_02</defName>
        <label>C-7 Templar ergonomic grip</label>
        <description>A contoured ergonomic grip with pronounced finger indexing. It improves leverage, presentation and target transitions across the C-7's engagement envelope, at the cost of a small increase in weight.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <slotId>Grip</slotId>
        <texPath>Things/Weapon/C7Templar/C7_Grip2</texPath>
        <warmupTimeOffset>-0.08</warmupTimeOffset>
        <statOffsets>
            <AccuracyTouch>0.05</AccuracyTouch>
            <AccuracyShort>0.04</AccuracyShort>
            <AccuracyMedium>0.02</AccuracyMedium>
            <AccuracyLong>0.01</AccuracyLong>
            <Mass>0.08</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C7Templar_Grip_03</defName>
        <label>C-7 Templar skeletonized grip</label>
        <description>A hollowed grip that removes every nonessential section of material. It makes the C-7 faster to present, but sacrifices the rigid support needed for deliberate medium- and long-range fire.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <slotId>Grip</slotId>
        <texPath>Things/Weapon/C7Templar/C7_Grip3</texPath>
        <warmupTimeOffset>-0.12</warmupTimeOffset>
        <statOffsets>
            <AccuracyTouch>0.03</AccuracyTouch>
            <AccuracyShort>0.02</AccuracyShort>
            <AccuracyMedium>-0.03</AccuracyMedium>
            <AccuracyLong>-0.05</AccuracyLong>
            <Mass>-0.20</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C7Templar_Stock_01</defName>
        <label>frame tactical stock</label>
        <description>A rigid open-frame stock that stabilizes sustained bursts while retaining the balance expected of an assault rifle.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
        </compatiblePlatforms>
        <slotId>Stock</slotId>
        <texPath>Things/Weapon/C7Templar/C7_stock_01</texPath>
        <drawOverBody>true</drawOverBody>
        <statOffsets>
            <AccuracyTouch>-0.03</AccuracyTouch>
            <AccuracyShort>0.04</AccuracyShort>
            <AccuracyMedium>0.06</AccuracyMedium>
            <AccuracyLong>0.02</AccuracyLong>
            <Mass>0.2</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C7Templar_Stock_02</defName>
        <label>light folding stock</label>
        <description>A compact folding stock that strips weight from the C-7 and speeds presentation. It favors mobile close engagements over sustained long-range stability.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
        </compatiblePlatforms>
        <slotId>Stock</slotId>
        <texPath>Things/Weapon/C7Templar/C7_stock_02</texPath>
        <drawOverBody>true</drawOverBody>
        <warmupTimeOffset>-0.10</warmupTimeOffset>
        <statOffsets>
            <AccuracyTouch>0.04</AccuracyTouch>
            <AccuracyShort>0.02</AccuracyShort>
            <AccuracyMedium>-0.02</AccuracyMedium>
            <AccuracyLong>-0.04</AccuracyLong>
            <Mass>-0.3</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C7Templar_Ammo_01</defName>
        <label>5.8x42 tungsten-alloy penetrators</label>
        <description>5.8x42 tungsten-alloy armor-piercing rods shared with the C19 Dragoon.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <slotId>Magazine</slotId>
        <texPath>Things/Weapon/C7Templar/C7_magazine_01</texPath>
        <iconPath>Things/Projectile/Bullet_Small</iconPath>
        <excludesCombatExtended>true</excludesCombatExtended>
        <projectileOverride>PM_Bullet_C19Dragoon</projectileOverride>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <!-- Visual-only magazine used while vanilla APEX owns the ammunition behavior. -->
    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C7Templar_APEX_MagazineVisual</defName>
        <label>C-7 APEX locked magazine</label>
        <description>The retained magazine housing while the APEX twin-core system controls ammunition selection.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <slotId>Magazine</slotId>
        <texPath>Things/Weapon/C7Templar/C7_magazine_01</texPath>
        <isApex>true</isApex>
        <selectable>false</selectable>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C7Templar_Magazine_01</defName>
        <label>30-round assault magazine</label>
        <description>A compact 30-round C-7 assault magazine configured for Combat Extended ammunition handling.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <slotId>Magazine</slotId>
        <texPath>Things/Weapon/C7Templar/C7_magazine_01</texPath>
        <requiresCombatExtended>true</requiresCombatExtended>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C7Templar_Magazine_02</defName>
        <label>45-round extended magazine</label>
        <description>A longer C-7 Combat Extended magazine holding 45 rounds. Its additional capacity increases sustained fire but adds weight and slows reloads.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <slotId>Magazine</slotId>
        <texPath>Things/Weapon/C7Templar/C7_magazine_02</texPath>
        <requiresCombatExtended>true</requiresCombatExtended>
        <ceProvidesMagazineSize>true</ceProvidesMagazineSize>
        <ceMagazineSize>45</ceMagazineSize>
        <ceProvidesReloadTimeOffset>true</ceProvidesReloadTimeOffset>
        <ceReloadTimeOffset>0.35</ceReloadTimeOffset>
        <statOffsets>
            <Mass>0.3</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C7Templar_Laser_01</defName>
        <label>Ranger box laser</label>
        <description>A rugged boxed laser designator for fast close-range C-7 target acquisition. It helps the shooter drive bursts onto nearby targets, but contributes little at long range.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
            <li>PM_GunSmith_B25Bulwark</li>
            <li>PM_GunSmith_B9Zealot</li>
            <li>PM_GunSmith_B12Vanguard</li>
        </compatiblePlatforms>
        <slotId>Laser</slotId>
        <texPath>Things/Weapon/C7Templar/C7_Laser_01</texPath>
        <relativeToSlotId>Barrel</relativeToSlotId>
        <warmupTimeOffset>-0.05</warmupTimeOffset>
        <statOffsets>
            <AccuracyTouch>0.06</AccuracyTouch>
            <AccuracyShort>0.04</AccuracyShort>
            <AccuracyMedium>0.02</AccuracyMedium>
            <AccuracyLong>-0.02</AccuracyLong>
            <Mass>0.1</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C7Templar_APEX_TwinCore</defName>
        <label>C-7 APEX twin-core smart missile system</label>
        <description>A bespoke APEX fire-control conversion built around two miniature supercomputers. Activating it locks the C-7 into its long barrel, dedicated APEX laser and APEX smart sight, then replaces conventional 5.8x42 penetrators with guided 5.8x42 micro-missiles. Each missile follows a computed curved approach, punches harder than a C-31 Wisp submunition and finishes with a compact secondary blast.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <slotId>Optic</slotId>
        <texPath>Things/Weapon/C7Templar/APEX/C7_APEX_Sight</texPath>
        <isApex>true</isApex>
        <isApexEntry>true</isApexEntry>
        <drawOverBody>true</drawOverBody>
        <drawOrder>30</drawOrder>
        <projectileOverride>PM_Bullet_C7Templar_APEX_MicroMissile</projectileOverride>
        <ceAmmoSetOverride>PM_AmmoSet_C7Templar_APEX_MicroMissile</ceAmmoSetOverride>
        <rangeOffset>3</rangeOffset>
        <warmupTimeOffset>-0.18</warmupTimeOffset>
        <ignoresWeatherAccuracy>true</ignoresWeatherAccuracy>
        <ignoresSmokeAccuracy>true</ignoresSmokeAccuracy>
        <detectsCloaked>true</detectsCloaked>
        <ceShotSpreadOverride>0.020</ceShotSpreadOverride>
        <ceSwayFactorOverride>0.55</ceSwayFactorOverride>
        <ceSightsEfficiencyOverride>1.40</ceSightsEfficiencyOverride>
        <apexForcedParts>
            <li>
                <slotId>Barrel</slotId>
                <part>PM_C7Templar_Barrel_02</part>
            </li>
            <li>
                <slotId>Laser</slotId>
                <part>PM_C7Templar_APEX_Laser</part>
            </li>
            <li>
                <slotId>Magazine</slotId>
                <part>PM_C7Templar_APEX_MagazineVisual</part>
            </li>
        </apexForcedParts>
        <apexHiddenSlotIds>
            <li>Barrel</li>
            <li>Laser</li>
            <li>Magazine</li>
        </apexHiddenSlotIds>
        <statOffsets>
            <AccuracyTouch>0.06</AccuracyTouch>
            <AccuracyShort>0.08</AccuracyShort>
            <AccuracyMedium>0.10</AccuracyMedium>
            <AccuracyLong>0.10</AccuracyLong>
            <Mass>0.75</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C7Templar_APEX_Laser</defName>
        <label>C-7 APEX predictive laser</label>
        <description>The locked laser component of the C-7 APEX system. Its ranging pulses feed the twin supercomputers a continuous near-field trajectory solution.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <slotId>Laser</slotId>
        <texPath>Things/Weapon/C7Templar/APEX/C7_APEX_Laser</texPath>
        <relativeToSlotId>Barrel</relativeToSlotId>
        <isApex>true</isApex>
        <selectable>false</selectable>
        <drawOverBody>true</drawOverBody>
        <drawOrder>20</drawOrder>
        <warmupTimeOffset>-0.10</warmupTimeOffset>
        <statOffsets>
            <AccuracyTouch>0.05</AccuracyTouch>
            <AccuracyShort>0.05</AccuracyShort>
            <AccuracyMedium>0.03</AccuracyMedium>
            <Mass>0.20</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C7Templar_Sight_01</defName>
        <label>millimeter-wave combat sight</label>
        <description>A fused millimeter-wave and optical fire-control sight. It cuts through weather, smoke and active camouflage while supplying a stable firing solution at every practical range.</description>
        <platformDef>PM_GunSmith_C7Templar</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C19Dragoon</li>
            <li>PM_GunSmith_B25Bulwark</li>
        </compatiblePlatforms>
        <slotId>Optic</slotId>
        <texPath>Things/Weapon/C7Templar/C7_Optic_01</texPath>
        <ignoresWeatherAccuracy>true</ignoresWeatherAccuracy>
        <ignoresSmokeAccuracy>true</ignoresSmokeAccuracy>
        <detectsCloaked>true</detectsCloaked>
        <statOffsets>
            <AccuracyTouch>0.04</AccuracyTouch>
            <AccuracyShort>0.04</AccuracyShort>
            <AccuracyMedium>0.04</AccuracyMedium>
            <AccuracyLong>0.04</AccuracyLong>
            <Mass>0.1</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

</Defs>
