<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C19Dragoon_Barrel_01</defName>
        <label>precision coil barrel</label>
        <description>A precision coil barrel tuned for medium- and long-range firing solutions. Its longer acceleration path provides higher projectile velocity, but the added weight sacrifices close-range handling.</description>
        <platformDef>PM_GunSmith_C19Dragoon</platformDef>
        <slotId>Barrel</slotId>
        <texPath>Things/Weapon/C19/C19_Barrel1</texPath>
        <rangeOffset>4</rangeOffset>
        <projectileSpeedFactor>1.08</projectileSpeedFactor>
        <childSlotAnchors>
            <li>
                <slotId>Muzzle</slotId>
                <offset>(-0.6986, 0.0087)</offset>
            </li>
            <li>
                <slotId>Laser</slotId>
                <offset>(-0.1664, -0.0135)</offset>
            </li>
            <li>
                <slotId>UnderBarrel</slotId>
                <offset>(0.1120, 0.1221)</offset>
            </li>
            <li>
                <slotId>FrontIronSight</slotId>
                <offset>(0.1044, -0.0152)</offset>
            </li>
        </childSlotAnchors>
        <statOffsets>
            <AccuracyTouch>-0.03</AccuracyTouch>
            <AccuracyMedium>0.04</AccuracyMedium>
            <AccuracyLong>0.06</AccuracyLong>
            <Mass>0.2</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C19Dragoon_Grip_01</defName>
        <label>standard grip</label>
        <description>A standard pistol grip that provides stable, predictable handling.</description>
        <platformDef>PM_GunSmith_C19Dragoon</platformDef>
        <slotId>Grip</slotId>
        <texPath>Things/Weapon/C19/C19_Grip1</texPath>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C19Dragoon_Grip_02</defName>
        <label>ergonomic grip</label>
        <description>A contoured ergonomic grip with pronounced finger indexing, improving leverage, presentation, and target transitions.</description>
        <platformDef>PM_GunSmith_C19Dragoon</platformDef>
        <slotId>Grip</slotId>
        <texPath>Things/Weapon/C19/C19_Grip2</texPath>
        <warmupTimeOffset>-0.08</warmupTimeOffset>
        <statOffsets>
            <AccuracyTouch>0.05</AccuracyTouch>
            <AccuracyShort>0.04</AccuracyShort>
            <AccuracyMedium>0.02</AccuracyMedium>
            <AccuracyLong>0.01</AccuracyLong>
            <Mass>0.08</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C19Dragoon_Grip_03</defName>
        <label>skeletonized lightweight grip</label>
        <description>A skeletonized grip that removes all nonessential material, letting the shooter shoulder the weapon faster but sacrificing the rigid support needed for accurate long-range fire.</description>
        <platformDef>PM_GunSmith_C19Dragoon</platformDef>
        <slotId>Grip</slotId>
        <texPath>Things/Weapon/C19/C19_Grip3</texPath>
        <warmupTimeOffset>-0.12</warmupTimeOffset>
        <statOffsets>
            <AccuracyTouch>0.03</AccuracyTouch>
            <AccuracyShort>0.02</AccuracyShort>
            <AccuracyLong>-0.05</AccuracyLong>
            <Mass>-0.20</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C19Dragoon_Stock_01</defName>
        <label>light folding stock</label>
        <description>A compact folding stock that provides stable support and increases movement speed. It can also be folded while moving to improve portability.</description>
        <platformDef>PM_GunSmith_C19Dragoon</platformDef>
        <compatiblePlatforms>
            <li>PM_GunSmith_C7Templar</li>
        </compatiblePlatforms>
        <slotId>Stock</slotId>
        <texPath>Things/Weapon/C19/C19_Stock1</texPath>
        <wielderMoveSpeedOffset>0.15</wielderMoveSpeedOffset>
        <statOffsets>
            <AccuracyTouch>0.03</AccuracyTouch>
            <AccuracyShort>0.02</AccuracyShort>
            <AccuracyMedium>0.02</AccuracyMedium>
            <Mass>-0.2</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C19Dragoon_Ammo_01</defName>
        <label>5.8x42 tungsten-alloy penetrators</label>
        <description>A tungsten-alloy armor-piercing projectile capable of penetrating the armor of light infantry fighting vehicles and robots.</description>
        <platformDef>PM_GunSmith_C19Dragoon</platformDef>
        <slotId>Magazine</slotId>
        <texPath>Things/Weapon/C19/C19_Mag1</texPath>
        <iconPath>Things/Projectile/Bullet_Small</iconPath>
        <excludesCombatExtended>true</excludesCombatExtended>
        <projectileOverride>PM_Bullet_C19Dragoon</projectileOverride>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C19Dragoon_Magazine_01</defName>
        <label>30-round 5.8x42 magazine</label>
        <description>A standard transparent polymer magazine.</description>
        <platformDef>PM_GunSmith_C19Dragoon</platformDef>
        <slotId>Magazine</slotId>
        <texPath>Things/Weapon/C19/C19_Mag1</texPath>
        <requiresCombatExtended>true</requiresCombatExtended>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_C19Dragoon_Magazine_02</defName>
        <label>30-round 5.8x42 flip magazine</label>
        <description>Two opposed 30-round magazines bound together for a faster flip reload. It reduces reload time but adds weight.</description>
        <platformDef>PM_GunSmith_C19Dragoon</platformDef>
        <slotId>Magazine</slotId>
        <texPath>Things/Weapon/C19/C19_Mag2</texPath>
        <requiresCombatExtended>true</requiresCombatExtended>
        <ceProvidesReloadTimeOffset>true</ceProvidesReloadTimeOffset>
        <ceReloadTimeOffset>-0.45</ceReloadTimeOffset>
        <statOffsets>
            <Mass>0.2</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

</Defs>
