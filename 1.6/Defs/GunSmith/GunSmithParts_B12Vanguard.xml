<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_B12Vanguard_Barrel_01</defName>
        <label>8-round automatic barrel</label>
        <description>A short barrel with an integrated 8-round tube and a three-shot automatic firing cycle, suited to breaching in confined spaces.</description>
        <platformDef>PM_GunSmith_B12Vanguard</platformDef>
        <slotId>Barrel</slotId>
        <texPath>Things/Weapon/B12/B12_Barrel1</texPath>
        <ceFullAuto>true</ceFullAuto>
        <ceProvidesMagazineSize>true</ceProvidesMagazineSize>
        <ceMagazineSize>8</ceMagazineSize>
        <burstShotCountOverride>3</burstShotCountOverride>
        <ticksBetweenBurstShotsOverride>8</ticksBetweenBurstShotsOverride>
        <childSlotAnchors>
            <li>
                <slotId>Laser</slotId>
                <offset>(-0.0481, -0.0100)</offset>
            </li>
            <li>
                <slotId>FrontIronSight</slotId>
                <offset>(-0.0021, 0.0062)</offset>
            </li>
        </childSlotAnchors>
        <statOffsets>
            <AccuracyTouch>0.06</AccuracyTouch>
            <AccuracyShort>0.02</AccuracyShort>
            <AccuracyMedium>-0.04</AccuracyMedium>
            <AccuracyLong>-0.10</AccuracyLong>
            <RangedWeapon_Cooldown>0.65</RangedWeapon_Cooldown>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_B12Vanguard_Barrel_02</defName>
        <label>15-round pump-action barrel</label>
        <description>A long barrel with an integrated 15-round tube and a pump-action firing cycle. It provides higher muzzle velocity, reduced muzzle flash and report, and improved recoil control.</description>
        <platformDef>PM_GunSmith_B12Vanguard</platformDef>
        <slotId>Barrel</slotId>
        <texPath>Things/Weapon/B12/B12_Barrel2</texPath>
        <ceProvidesMagazineSize>true</ceProvidesMagazineSize>
        <ceMagazineSize>15</ceMagazineSize>
        <ceReloadOneAtATime>true</ceReloadOneAtATime>
        <ceProvidesReloadTimeOffset>true</ceProvidesReloadTimeOffset>
        <ceReloadTimeOffset>-2.90</ceReloadTimeOffset>
        <warmupTimeOffset>0.20</warmupTimeOffset>
        <childSlotAnchors>
            <li>
                <slotId>Laser</slotId>
                <offset>(-0.1703, -0.0049)</offset>
            </li>
            <li>
                <slotId>FrontIronSight</slotId>
                <offset>(-0.0701, 0.0053)</offset>
            </li>
        </childSlotAnchors>
        <statOffsets>
            <AccuracyTouch>-0.03</AccuracyTouch>
            <AccuracyShort>0.04</AccuracyShort>
            <AccuracyMedium>0.08</AccuracyMedium>
            <AccuracyLong>0.02</AccuracyLong>
            <Mass>0.35</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_B12Vanguard_Barrel_03</defName>
        <label>reinforced pump-action barrel</label>
        <description>An extended pump-action assembly. Its longer barrel provides higher muzzle velocity, reduced muzzle flash and report, and improved recoil control, while a detachable-magazine feed interface allows the operator to replace the entire ammunition supply instead of loading shells one at a time. The additional length and feed hardware make the weapon heavier and slower to bring on target.</description>
        <platformDef>PM_GunSmith_B12Vanguard</platformDef>
        <slotId>Barrel</slotId>
        <texPath>Things/Weapon/B12/B12_Barrel3</texPath>
        <rangeOffset>4</rangeOffset>
        <warmupTimeOffset>0.30</warmupTimeOffset>
        <projectileSpeedFactor>1.10</projectileSpeedFactor>
        <providedSlots>
            <li>
                <slotId>Magazine</slotId>
            </li>
        </providedSlots>
        <childSlotAnchors>
            <li>
                <slotId>Laser</slotId>
                <offset>(-0.0760, -0.0363)</offset>
            </li>
            <li>
                <slotId>FrontIronSight</slotId>
                <offset>(-0.0542, -0.0011)</offset>
            </li>
            <li>
                <slotId>Magazine</slotId>
                <offset>(0.2120, 0.1150)</offset>
            </li>
        </childSlotAnchors>
        <statOffsets>
            <AccuracyTouch>-0.08</AccuracyTouch>
            <AccuracyShort>0.01</AccuracyShort>
            <AccuracyMedium>0.10</AccuracyMedium>
            <AccuracyLong>0.08</AccuracyLong>
            <Mass>0.65</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_B12Vanguard_Grip_01</defName>
        <label>standard grip</label>
        <description>A standard pistol grip that provides stable, predictable handling.</description>
        <platformDef>PM_GunSmith_B12Vanguard</platformDef>
        <slotId>Grip</slotId>
        <texPath>Things/Weapon/B12/B12_Grip1</texPath>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_B12Vanguard_Grip_02</defName>
        <label>ergonomic grip</label>
        <description>A contoured ergonomic grip with pronounced finger indexing, improving leverage, presentation, and target transitions.</description>
        <platformDef>PM_GunSmith_B12Vanguard</platformDef>
        <slotId>Grip</slotId>
        <texPath>Things/Weapon/B12/B12_Grip2</texPath>
        <warmupTimeOffset>-0.08</warmupTimeOffset>
        <statOffsets>
            <AccuracyTouch>0.05</AccuracyTouch>
            <AccuracyShort>0.04</AccuracyShort>
            <AccuracyMedium>0.02</AccuracyMedium>
            <AccuracyLong>0.01</AccuracyLong>
            <Mass>0.08</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_B12Vanguard_Grip_03</defName>
        <label>skeletonized lightweight grip</label>
        <description>A skeletonized lightweight grip that removes all nonessential material, letting the shooter shoulder the weapon faster but sacrificing the rigid support needed for accurate long-range fire.</description>
        <platformDef>PM_GunSmith_B12Vanguard</platformDef>
        <slotId>Grip</slotId>
        <texPath>Things/Weapon/B12/B12_Grip3</texPath>
        <warmupTimeOffset>-0.12</warmupTimeOffset>
        <statOffsets>
            <AccuracyTouch>0.03</AccuracyTouch>
            <AccuracyShort>0.02</AccuracyShort>
            <AccuracyLong>-0.05</AccuracyLong>
            <Mass>-0.20</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_B12Vanguard_Stock_01</defName>
        <label>standard buttpad</label>
        <description>A standard bullpup buttpad for shouldered firing.</description>
        <platformDef>PM_GunSmith_B12Vanguard</platformDef>
        <slotId>Stock</slotId>
        <texPath>Things/Weapon/B12/B12_Stock1</texPath>
        <statOffsets>
            <AccuracyTouch>0.03</AccuracyTouch>
            <AccuracyShort>0.02</AccuracyShort>
            <Mass>0.1</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_B12Vanguard_Stock_02</defName>
        <label>ergonomic buttpad</label>
        <description>A contoured ergonomic buttpad that improves close-range pointing speed.</description>
        <platformDef>PM_GunSmith_B12Vanguard</platformDef>
        <slotId>Stock</slotId>
        <texPath>Things/Weapon/B12/B12_Stock2</texPath>
        <warmupTimeOffset>-0.05</warmupTimeOffset>
        <ceRecoilOverride>1.70</ceRecoilOverride>
        <statOffsets>
            <AccuracyShort>0.04</AccuracyShort>
            <AccuracyMedium>0.05</AccuracyMedium>
            <AccuracyLong>0.03</AccuracyLong>
            <RangedWeapon_Cooldown>-0.10</RangedWeapon_Cooldown>
            <Mass>0.25</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_B12Vanguard_Ammo_01</defName>
        <label>short detachable magazine</label>
        <description>The standard short magazine used by a magazine-fed barrel when Combat Extended is not active.</description>
        <platformDef>PM_GunSmith_B12Vanguard</platformDef>
        <slotId>Magazine</slotId>
        <texPath>Things/Weapon/B12/B12_Mag1</texPath>
        <iconPath>Things/Weapon/B12/B12_Ammo_DragonBreath</iconPath>
        <selectable>false</selectable>
        <excludesCombatExtended>true</excludesCombatExtended>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_B12Vanguard_Magazine_01</defName>
        <label>10-round detachable magazine</label>
        <description>A compact 10-round magazine.</description>
        <platformDef>PM_GunSmith_B12Vanguard</platformDef>
        <slotId>Magazine</slotId>
        <texPath>Things/Weapon/B12/B12_Mag1</texPath>
        <requiresCombatExtended>true</requiresCombatExtended>
        <ceProvidesMagazineSize>true</ceProvidesMagazineSize>
        <ceMagazineSize>10</ceMagazineSize>
        <statOffsets>
            <Mass>0.15</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

    <ProtossMech.GunSmith.GunSmithPartDef>
        <defName>PM_B12Vanguard_Magazine_02</defName>
        <label>20-round extended magazine</label>
        <description>An extended 20-round magazine that improves sustained fire, but whose extra weight increases reload time.</description>
        <platformDef>PM_GunSmith_B12Vanguard</platformDef>
        <slotId>Magazine</slotId>
        <texPath>Things/Weapon/B12/B12_Mag2</texPath>
        <requiresCombatExtended>true</requiresCombatExtended>
        <ceProvidesMagazineSize>true</ceProvidesMagazineSize>
        <ceMagazineSize>20</ceMagazineSize>
        <ceProvidesReloadTimeOffset>true</ceProvidesReloadTimeOffset>
        <ceReloadTimeOffset>0.65</ceReloadTimeOffset>
        <statOffsets>
            <Mass>0.55</Mass>
        </statOffsets>
    </ProtossMech.GunSmith.GunSmithPartDef>

</Defs>
