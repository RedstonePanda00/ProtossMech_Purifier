<?xml version="1.0" encoding="utf-8"?>
<Patch>

    <Operation Class="CombatExtended.PatchOperationMakeGunCECompatible">
        <defName>PM_GunC7Templar</defName>
        <statBases>
            <RangedWeapon_Cooldown>0.35</RangedWeapon_Cooldown>
            <SightsEfficiency>1</SightsEfficiency>
            <ShotSpread>0.05</ShotSpread>
            <SwayFactor>1.0</SwayFactor>
            <Bulk>10</Bulk>
        </statBases>
        <Properties>
            <recoilAmount>1.10</recoilAmount>
            <verbClass>CombatExtended.Verb_ShootCE</verbClass>
            <hasStandardCommand>true</hasStandardCommand>
            <defaultProjectile>PM_Bullet_C19Dragoon_CE</defaultProjectile>
            <warmupTime>0.8</warmupTime>
            <range>51</range>
            <burstShotCount>6</burstShotCount>
            <ticksBetweenBurstShots>5</ticksBetweenBurstShots>
            <soundCast>Shot_AssaultRifle</soundCast>
            <soundCastTail>GunTail_Medium</soundCastTail>
            <muzzleFlashScale>7</muzzleFlashScale>
        </Properties>
        <AmmoUser>
            <magazineSize>30</magazineSize>
            <reloadTime>2.4</reloadTime>
            <ammoSet>PM_AmmoSet_C19Dragoon</ammoSet>
        </AmmoUser>
        <FireModes>
            <aimedBurstShotCount>3</aimedBurstShotCount>
            <aiUseBurstMode>true</aiUseBurstMode>
            <aiAimMode>AimedShot</aiAimMode>
        </FireModes>
        <weaponTags>
            <li>CE_AI_AR</li>
        </weaponTags>
    </Operation>

    <Operation Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="PM_GunC7Templar"]/tools</xpath>
        <value>
            <tools>
                <li Class="CombatExtended.ToolCE">
                    <label>stock</label>
                    <capacities>
                        <li>Blunt</li>
                    </capacities>
                    <power>8</power>
                    <cooldownTime>1.55</cooldownTime>
                    <chanceFactor>1.5</chanceFactor>
                    <armorPenetrationBlunt>2.755</armorPenetrationBlunt>
                    <linkedBodyPartsGroup>Stock</linkedBodyPartsGroup>
                </li>
                <li Class="CombatExtended.ToolCE">
                    <label>barrel</label>
                    <capacities>
                        <li>Blunt</li>
                    </capacities>
                    <power>5</power>
                    <cooldownTime>2.02</cooldownTime>
                    <armorPenetrationBlunt>1.630</armorPenetrationBlunt>
                    <linkedBodyPartsGroup>Barrel</linkedBodyPartsGroup>
                </li>
                <li Class="CombatExtended.ToolCE">
                    <label>muzzle</label>
                    <capacities>
                        <li>Poke</li>
                    </capacities>
                    <power>8</power>
                    <cooldownTime>1.55</cooldownTime>
                    <armorPenetrationBlunt>2.755</armorPenetrationBlunt>
                    <linkedBodyPartsGroup>Muzzle</linkedBodyPartsGroup>
                </li>
            </tools>
        </value>
    </Operation>

    <Operation Class="PatchOperationAddModExtension">
        <xpath>Defs/ThingDef[defName="PM_GunC7Templar"]</xpath>
        <value>
            <li Class="CombatExtended.GunDrawExtension">
                <DrawSize>4.8,2.4</DrawSize>
                <DrawOffset>0,0</DrawOffset>
            </li>
        </value>
    </Operation>

    <!-- Vanilla APEX forces a visual-only magazine while it owns ammunition behavior. Under CE
         the Magazine slot represents detachable magazine hardware, while ammo type is constrained
         by ceAmmoSetOverride, so restore the real magazine slot only in the CE load folder. -->
    <Operation Class="PatchOperationRemove">
        <xpath>Defs/ProtossMech.GunSmith.GunSmithPartDef[defName="PM_C7Templar_APEX_TwinCore"]/apexForcedParts/li[slotId="Magazine"]</xpath>
    </Operation>

    <Operation Class="PatchOperationRemove">
        <xpath>Defs/ProtossMech.GunSmith.GunSmithPartDef[defName="PM_C7Templar_APEX_TwinCore"]/apexHiddenSlotIds/li[text()="Magazine"]</xpath>
    </Operation>

</Patch>
