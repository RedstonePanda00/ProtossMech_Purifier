    <RecipeDef ParentName="AmmoRecipeBase">
        <defName>MakePM_Ammo_R42DeadEye_Short</defName>
        <label>make 8×80 mm tungsten-rhenium rail slugs x150</label>
        <description>Print 150 shortened 8×80 mm tungsten-rhenium rail slugs from one unit of Solarite.</description>
        <jobString>Making 8×80 mm rail slugs.</jobString>
        <researchPrerequisite>PM_NuclearFusion</researchPrerequisite>
        <recipeUsers Inherit="false">
            <li>ProtossForge</li>
        </recipeUsers>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>PM_Solarite</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>PM_Solarite</li>
            </thingDefs>
        </fixedIngredientFilter>
        <products>
            <PM_Ammo_R42DeadEye_Short>150</PM_Ammo_R42DeadEye_Short>
        </products>
        <workAmount>2500</workAmount>
    </RecipeDef>

