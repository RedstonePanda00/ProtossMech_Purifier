    <CombatExtended.AmmoCategoryDef>
        <defName>PM_R42RailSlug_Short</defName>
        <label>short rail slug (8×80mm)</label>
        <labelShort>8×80 AP</labelShort>
        <description>A shortened 8 mm tungsten-rhenium rail slug. It preserves the rifle's firing behavior while reducing armor penetration.</description>
    </CombatExtended.AmmoCategoryDef>

    <CombatExtended.AmmoCategoryDef>
        <defName>PM_R42RailSlug_Standard</defName>
