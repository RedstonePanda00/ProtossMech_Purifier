<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <ThingCategoryDef>
        <defName>PM_AmmoC7Templar</defName>
        <label>C-7 5.8 mm coil ammunition</label>
        <parent>AmmoRifles</parent>
        <iconPath>UI/Icons/ThingCategories/CaliberRifle</iconPath>
    </ThingCategoryDef>

    <CombatExtended.AmmoSetDef>
        <defName>PM_AmmoSet_C7Templar</defName>
        <label>C-7 5.8 mm coil ammunition</label>
        <ammoTypes>
            <PM_Ammo_C7Templar_AP>PM_Bullet_C7Templar_CE</PM_Ammo_C7Templar_AP>
        </ammoTypes>
        <similarTo>AmmoSet_Rifle</similarTo>
    </CombatExtended.AmmoSetDef>

    <ThingDef Class="CombatExtended.AmmoDef" ParentName="SmallAmmoBase">
        <defName>PM_Ammo_C7Templar_AP</defName>
        <label>5.8 mm tungsten coil round (AP)</label>
        <description>A tungsten-alloy armor-piercing round designed for the C-7 Templar's hybrid coil accelerator.</description>
        <graphicData>
            <texPath>Things/Ammo/Rifle/Battlerifle/AP</texPath>
            <graphicClass>Graphic_StackCount</graphicClass>
        </graphicData>
        <statBases>
            <Mass>0.012</Mass>
            <Bulk>0.012</Bulk>
        </statBases>
        <ammoClass>ArmorPiercing</ammoClass>
        <cookOffProjectile>PM_Bullet_C7Templar_CE</cookOffProjectile>
        <tradeTags>
            <li>CE_AutoEnableTrade</li>
            <li>CE_AutoEnableCrafting</li>
        </tradeTags>
        <thingCategories>
            <li>PM_AmmoC7Templar</li>
        </thingCategories>
    </ThingDef>

    <RecipeDef ParentName="AmmoRecipeBase">
        <defName>MakePM_Ammo_C7Templar_AP</defName>
        <label>make 5.8 mm tungsten coil rounds (AP) x500</label>
        <description>Craft 500 armor-piercing tungsten coil rounds for the C-7 Templar.</description>
        <jobString>Making C-7 tungsten coil rounds.</jobString>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>Steel</li>
                    </thingDefs>
                </filter>
                <count>18</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>Steel</li>
            </thingDefs>
        </fixedIngredientFilter>
        <products>
            <PM_Ammo_C7Templar_AP>500</PM_Ammo_C7Templar_AP>
        </products>
        <workAmount>2160</workAmount>
    </RecipeDef>

    <!-- The default barrel supplies +1 damage, x1.10 velocity and +5% penetration. -->
    <ThingDef ParentName="BaseBulletCE">
        <defName>PM_Bullet_C7Templar_CE</defName>
        <label>5.8 mm tungsten coil projectile</label>
        <graphicData>
            <texPath>Things/Projectile/Bullet_Small</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <damageDef>Bullet</damageDef>
            <damageAmountBase>9</damageAmountBase>
            <armorPenetrationSharp>13.333333</armorPenetrationSharp>
            <armorPenetrationBlunt>38.095238</armorPenetrationBlunt>
            <speed>190.909091</speed>
            <dropsCasings>false</dropsCasings>
        </projectile>
    </ThingDef>

</Defs>
