    <RecipeDef ParentName="AmmoRecipeBase">
        <defName>MakePM_Ammo_C31Tempest_SAPHE</defName>
        <label>make 30 mm SAPHE gun grenades x80</label>
        <description>Craft 80 anti-structure 30 mm SAPHE gun grenades.</description>
        <jobString>Making C-31 30 mm SAPHE gun grenades.</jobString>
        <researchPrerequisite>PM_NuclearFusion</researchPrerequisite>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>Steel</li>
                    </thingDefs>
                </filter>
                <count>48</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Chemfuel</li>
                    </thingDefs>
                </filter>
                <count>8</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>Steel</li>
                <li>Chemfuel</li>
            </thingDefs>
        </fixedIngredientFilter>
        <products>
            <PM_Ammo_C31Tempest_SAPHE>80</PM_Ammo_C31Tempest_SAPHE>
        </products>
        <workAmount>7000</workAmount>
    </RecipeDef>

