<Defs>

    <CombatExtended.AmmoCategoryDef>
        <defName>PM_C31Tempest_30mmSAPHE</defName>
        <label>30 mm SAPHE gun grenade</label>
        <labelShort>30 mm SAPHE</labelShort>
        <description>A 30 mm anti-structure semi-armor-piercing high-explosive gun grenade. A small tungsten core provides limited direct penetration before the grenade detonates.</description>
    </CombatExtended.AmmoCategoryDef>

    <CombatExtended.AmmoCategoryDef>
        <defName>PM_C31Tempest_30mmPlasma</defName>
        <label>30 mm plasma gun grenade</label>
        <labelShort>30 mm plasma</labelShort>
        <description>A miniature inferno-cannon plasma grenade. It deals vaporizing thermal damage with triple the heat penetration of the standard SAPHE grenade.</description>
    </CombatExtended.AmmoCategoryDef>

    <CombatExtended.AmmoCategoryDef>
        <defName>PM_C31Tempest_30mmWisp</defName>
        <label>30 mm Wisp swarm grenade</label>
        <labelShort>30 mm Wisp</labelShort>
        <description>A carrier grenade that releases five Wisp micro-missiles on impact. Each Wisp curves toward the nearest hostile target.</description>
    </CombatExtended.AmmoCategoryDef>

